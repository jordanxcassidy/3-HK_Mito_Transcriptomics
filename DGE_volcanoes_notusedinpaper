myDesign$batch1 <- factor(c('1','1','2','2','1','1','2', '2' ,'2','2', '1','1','2','2', '3','4','5'))
head(quant_data)
colnames(quant_data)


#cleaning/tidying data
# printing original rownames of data frame 
