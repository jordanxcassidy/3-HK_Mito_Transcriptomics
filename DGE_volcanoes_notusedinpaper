# Load packages
library(tidyverse)
library(ggrepel)

# A short function for outputting the tables
knitr_table <- function(x) {
  x %>% 
    knitr::kable(format = "html", digits = Inf, 
                 format.args = list(big.mark = ",")) %>%
    kableExtra::kable_styling(font_size = 15)
}

data <- convhigh %>% 
  mutate(
    Expression = case_when(log2FoldChange >= log(0.55) & padj <= 0.05 ~ "Up-regulated",
                           log2FoldChange <= -log(0.55) & padj <= 0.05 ~ "Down-regulated",
                           TRUE ~ "Unchanged")
  )
head(data) %>% 
  knitr_table()

p2 <- ggplot(data, aes(log2FoldChange, -log10(padj))) +
  geom_point(aes(color = Expression), size = 3) +
  xlab(expression("log"[2]*"FC")) + 
  ylab(expression("-log"[10]*"padj")) +
  scale_color_manual(values = c("dodgerblue3", "firebrick3")) +
  theme_bw(10) +
  guides(colour = guide_legend(override.aes = list(size=1.5))) 
p2  

