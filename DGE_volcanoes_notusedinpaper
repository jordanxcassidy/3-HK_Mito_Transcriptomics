# Add Experiment Design Info
myDesign <- data.frame(
  sampleID = colnames(quant_data)[-1],
  condition = c( "low", "low", "low", "low", "control", "control", "control", "control", "high", "high", "extra", "extra", "extra", "extra", "high", "high", "high"))
