fviz_pca_ind(pca, pointshape=20, axes = c(1,2)) + scale_color_discrete()+ggtitle('')+coord_fixed()
fviz_pca_ind(pca, pointshape=20, axes = c(2,3)) + scale_color_discrete()+ggtitle('')+coord_fixed()
plotPCA(vsd, intgroup=c("condition", "batch"))

#plot fancy pca
