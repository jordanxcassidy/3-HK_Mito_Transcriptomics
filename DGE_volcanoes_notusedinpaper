#make deseq2 dataset
dds <- DESeqDataSetFromMatrix(countData = quant_data,
                              colData = myDesign,
                              design = ~ batch + condition)
dds

#This command allow you to filter out the low read counts, the NA results and 0 results. So you take just the one you want to keep and store
#them into the "keep" vector. 

smallestGroupSize <- 3
keep <- rowSums(counts(dds) >= 10) >= smallestGroupSize
dds <- dds[keep,]


#To run the differential expression genes analysis and save the data in a vector (dds.E)
dds.E<-DESeq(dds)
res <- results(dds.E)
res

resOrdered <- res[order(res$pvalue),]
summary(res)
sum(res$padj < 0.1, na.rm=TRUE)

# cooks plot
par(mar=c(8,5,2,2))
boxplot(log10(assays(dds.E)[["cooks"]]), range=0, las=2)

#transform for pca visualisation
vsd <- vst(dds.E, blind=FALSE)
rld <- rlog(dds.E, blind=FALSE)
head(assay(vsd), 3)

ntd <- normTransform(dds.E)

#limma batch effect removed
assay(vsd)<-removeBatchEffect(assay(vsd), vsd$batch)

#heatmap
library("pheatmap")
select <- order(rowMeans(counts(dds.E,normalized=TRUE)),
                decreasing=TRUE)[1:50]
df <- as.data.frame(colData(dds,E)[,c("batch","condition", "batch1")])
pheatmap(assay(ntd)[select,], cluster_rows=FALSE, show_rownames=TRUE,
         cluster_cols=T, annotation_col=df)


#plot pca not fancy
pca=prcomp(t(assay(vsd)))
library(factoextra)
